# Application Configuration
VITE_APP_MODE=development
VITE_API_BASE_URL=/api

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_DIAGNOSTICS=false

# Security
VITE_ENABLE_RATE_LIMITING=true
VITE_MAX_REQUESTS_PER_MINUTE=60

# Logging
VITE_LOG_LEVEL=info
VITE_ENABLE_CONSOLE_LOGGING=true

# Database Configuration (SQLite)
VITE_DB_PATH=./data/survey.db
VITE_DB_BACKUP_PATH=./data/backups
VITE_ENABLE_AUTO_BACKUP=true
VITE_BACKUP_INTERVAL_HOURS=24